---
layout: default
title: Como Funciona
---
<% fn = site.data.content.funcionamento %>
<section class="slide slide--top">
  <div style="animation:fadeUp .5s .05s both;margin-bottom:14px">
    <span class="slide-tag"><%= fn.tag %></span>
  </div>
  <h2 class="slide-title slide-title--lg" style="animation:fadeUp .5s .15s both;margin-bottom:36px">
    <%= fn.title_1 %><br><span class="neon"><%= fn.title_2 %></span>
  </h2>
  <div class="g2" style="animation:fadeUp .5s .3s both">
    <% fn.steps.each_with_index do |step, i| %>
      <div class="step-card" style="animation-delay:<%= i * 0.07 %>s">
        <div class="step-card__icon"><%= step.icon %></div>
        <div>
          <div class="step-card__num"><%= step.num %></div>
          <div class="step-card__title"><%= step.title %></div>
          <p class="step-card__desc"><%= step.desc.strip %></p>
        </div>
      </div>
    <% end %>
  </div>
</section>
