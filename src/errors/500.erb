permalink: /500.html
layout: default
---
<section class="slide slide--center" style="overflow:hidden">
  <div class="cover-grid"></div>
  <div class="cover-glow"
    style="opacity:.3;background:radial-gradient(circle,rgba(255,80,80,.08) 0%,transparent 70%)"></div>

  <div
    style="position:relative;z-index:1;max-width:560px;width:100%;text-align:center">

    <div style="animation:fadeUp .5s .05s both;margin-bottom:20px">
      <span class="slide-tag"
        style="border-color:rgba(255,80,80,.5);color:#ff6b6b;background:rgba(255,80,80,.05)">
        <span
          style="width:4px;height:4px;border-radius:50%;background:#ff6b6b;box-shadow:0 0 6px #ff6b6b;display:inline-block;margin-right:8px"></span>
        Erro do Servidor
      </span>
    </div>

    <div style="animation:fadeUp .5s .15s both;margin-bottom:8px">
      <div style="
        font-family:var(--font-mono);
        font-weight:700;
        font-size:clamp(100px,22vw,180px);
        line-height:.85;
        letter-spacing:-.06em;
        color:var(--gray2);
        text-shadow:0 0 80px rgba(255,80,80,.08);
        animation:glitch 3s infinite;
        user-select:none;
      ">500</div>
    </div>

    <div style="animation:fadeUp .5s .25s both;margin-bottom:12px">
      <h1 style="
        font-family:var(--font-mono);
        font-size:clamp(18px,3vw,28px);
        font-weight:700;
        color:var(--white);
        letter-spacing:-.02em;
      ">Algo quebrou por dentro.</h1>
    </div>

    <p class="slide-lead" style="
      animation:fadeUp .5s .35s both;
      margin:0 auto 40px;
      font-size:clamp(12px,1.4vw,14px);
    ">
      O excesso de ordem também colapsa.<br>
      Nossa equipe já foi notificada. Tente novamente em instantes.
    </p>

    <div class="btn-group" style="animation:fadeUp .5s .45s both">
      <a href="/" class="btn-primary" style="margin:0 auto">← Voltar ao
        início</a>
      <a href="javascript:location.reload()" class="btn-secondary"
        style="margin:0 auto">Tentar novamente</a>
    </div>

    <div style="
      animation:fadeUp .5s .55s both;
      margin-top:48px;
      padding:14px 20px;
      border:1px solid var(--gray2);
      border-radius:var(--radius-sm);
      background:var(--surface);
      display:inline-flex;
      align-items:center;
      gap:10px;
    ">
      <span
        style="width:6px;height:6px;border-radius:50%;background:#ff6b6b;box-shadow:0 0 8px #ff6b6b;animation:pulse 1.4s infinite;flex-shrink:0"></span>
      <span
        style="font-family:var(--font-mono);font-size:10px;color:var(--muted);letter-spacing:.06em">
        STATUS: ERRO INTERNO &nbsp;·&nbsp; HTTP 500
      </span>
    </div>

  </div>
</section>
